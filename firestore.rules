rules_version = '2';

// AKM Music — Firestore security rules
// Deploy: Firebase console → Firestore Database → Rules → paste → Publish.
// Keep the admin email list in sync with AKM_ADMIN_EMAILS in firebase-config.js.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['sales@akm-music.com']
        && request.auth.token.email_verified == true;
    }

    // Catalog overrides: public read (shop filters listings), admin write.
    match /siteConfig/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: anyone may create a sane-looking order; only admin reads/updates.
    match /orders/{id} {
      allow create: if request.resource.data.keys().hasAll(['items', 'total'])
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50
        && request.resource.data.total is number
        && request.resource.data.total >= 0;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // Bookings (repairs / classes / studio / rentals): same pattern.
    match /bookings/{id} {
      allow create: if request.resource.data.keys().hasAll(['type'])
        && request.resource.data.type in ['repair', 'class', 'studio', 'rental'];
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // ⚠️ ONLY for a fresh, website-only project. If you are using the SAME
    // Firebase project as AKM-POS, DELETE this catch-all block and instead
    // ADD the three match blocks above into your existing POS rules —
    // otherwise this would lock the POS out of its own collections.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
